# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/webhook

# Claude — set ONE of these two:
# 1) pay-per-token API key from console.anthropic.com, OR
# 2) a token from `claude setup-token` if you have a Pro/Max/Team/Enterprise
#    subscription (no separate billing needed) — run it locally where you're
#    already logged into Claude Code, then paste the printed token here.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Voice transcription (local whisper.cpp, no external API/key needed)
WHISPER_MODEL=base
WHISPER_MODEL_ROOT=/app/whisper-models

# Agent sandbox
AGENT_WORKDIR=/data/workspace
DB_PATH=/data/bot.sqlite

# Server
PORT=3000
PUBLIC_URL=
